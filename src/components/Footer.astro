---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-border-subtle mt-auto pt-16 pb-8">
    <div class="max-w-6xl mx-auto px-8">
        <!-- 4-column grid -->
        <div
            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16"
        >
            <!-- Brand & Social -->
            <div class="flex flex-col gap-4">
                <a href="/" class="flex items-center gap-2">
                    <div
                        class="w-6 h-6 rounded-full bg-white flex items-center justify-center"
                    >
                        <div class="w-1 h-1 bg-black rounded-full"></div>
                    </div>
                    <span
                        class="text-lg font-bold tracking-[0.15em] uppercase text-white"
                    >
                        FluxDev
                    </span>
                </a>
                <p class="text-sm text-text-faint leading-relaxed max-w-xs">
                    Un espacio para compartir conocimiento sobre desarrollo,
                    tecnología y crecimiento personal.
                </p>
                <div class="flex gap-4 mt-2">
                    <!-- Instagram -->
                    <a
                        href="https://instagram.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-text-muted hover:text-white transition-all hover:scale-110"
                        aria-label="Instagram"
                    >
                        <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
                            <path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                            ></path>
                        </svg>
                    </a>
                    <!-- YouTube -->
                    <a
                        href="https://youtube.com"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-text-muted hover:text-white transition-all hover:scale-110"
                        aria-label="YouTube"
                    >
                        <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
                            <path
                                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
                            ></path>
                        </svg>
                    </a>
                    <!-- GitHub -->
                    <a
                        href="https://github.com/ivangtx19"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-text-muted hover:text-white transition-all hover:scale-110"
                        aria-label="GitHub"
                    >
                        <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24">
                            <path
                                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                            ></path>
                        </svg>
                    </a>
                </div>
            </div>

            <!-- Navigation -->
            <div class="flex flex-col gap-4">
                <h3
                    class="font-bold text-white uppercase tracking-wider text-sm"
                >
                    Navegación
                </h3>
                <ul class="flex flex-col gap-3 text-sm text-text-muted">
                    <li>
                        <a href="/" class="hover:text-white transition-colors"
                            >Inicio</a
                        >
                    </li>
                    <li>
                        <a
                            href="/about"
                            class="hover:text-white transition-colors">About</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Legal -->
            <div class="flex flex-col gap-4">
                <h3
                    class="font-bold text-white uppercase tracking-wider text-sm"
                >
                    Legal
                </h3>
                <ul class="flex flex-col gap-3 text-sm text-text-muted">
                    <li>
                        <a
                            href="/legal/terms"
                            class="hover:text-white transition-colors"
                            >Términos y Condiciones</a
                        >
                    </li>
                    <li>
                        <a
                            href="/legal/privacy"
                            class="hover:text-white transition-colors"
                            >Política de Privacidad</a
                        >
                    </li>
                </ul>
            </div>

            <!-- Subscribe -->
            <div class="flex flex-col gap-4">
                <h3
                    class="font-bold text-white uppercase tracking-wider text-sm"
                >
                    Suscríbete
                </h3>
                <form
                    class="flex flex-col gap-3"
                    onsubmit="event.preventDefault();"
                >
                    <input
                        type="email"
                        placeholder="Tu email"
                        class="px-4 py-2 rounded-md border border-border-subtle bg-transparent text-text-muted text-sm focus:outline-none focus:border-white focus:ring-1 focus:ring-white transition-all"
                    />
                    <button
                        type="submit"
                        class="px-4 py-2 rounded-md bg-white text-black font-medium text-sm hover:bg-neutral-200 transition-colors"
                    >
                        Suscribirse
                    </button>
                </form>
            </div>
        </div>

        <!-- Bottom bar -->
        <div
            class="border-t border-border-subtle pt-8 flex flex-col items-center gap-4"
        >
            <p class="text-sm font-medium text-text-muted">
                Desarrollado por <span class="font-bold text-white">Sinx</span>
            </p>
            <div class="flex flex-wrap justify-center gap-2">
                {
                    ["Astro", "Payload CMS", "Tailwind", "Cloudflare"].map(
                        (tech) => (
                            <span class="px-3 py-1 text-xs font-medium rounded-full border border-border-subtle text-text-muted transition-all hover:border-white hover:text-white">
                                {tech}
                            </span>
                        ),
                    )
                }
            </div>
            <p class="text-xs text-text-faint">
                &copy; {currentYear} Fluxdev. Todos los derechos reservados.
            </p>
        </div>
    </div>
</footer>
