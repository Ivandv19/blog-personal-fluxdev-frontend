---
import SettingsMenu from "./SettingsMenu.tsx";
---

<header
    class="fixed top-0 left-0 right-0 z-50 backdrop-blur-xl bg-surface-overlay border-b border-border-subtle"
>
    <nav class="max-w-6xl mx-auto px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
            <img 
                src="/logo.png" 
                alt="FluxDev Logo" 
                class="w-8 h-8 rounded-full object-cover group-hover:scale-110 transition-transform border border-white/10" 
            />
            <span
                class="text-sm font-bold tracking-[0.15em] uppercase text-text-muted group-hover:text-white transition-colors"
            >
                FluxDev
            </span>
        </a>

        <SettingsMenu client:load />
    </nav>
</header>

<!-- Spacer to prevent content from hiding behind fixed header -->
<div class="h-20"></div>
