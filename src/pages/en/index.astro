---
import Layout from "../../layouts/Layout.astro";
import { getPosts } from "../../lib/payload";

const posts = await getPosts('en');

// Extraer tags únicos de todos los posts
const popularTags = [
	...new Set(posts.flatMap((p) => (p.tags ?? []).map((t) => t.value))),
].sort();
---

<Layout title="Thoughts on Software">
	<main class="max-w-3xl mx-auto px-6 py-20 md:py-40">
		<header class="mb-16">
			<h1
				class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tight leading-tight text-text-heading"
			>
				Software development, personal growth, tutorials, and <span
					class="text-brand">a bit about me.</span
				>
			</h1>
			<p
				class="text-base text-text-secondary leading-relaxed max-w-2xl mb-10"
			>
				Welcome to my blog! I'll be sharing articles about
				software development, tech and productivity. My goal
				is to help you grow professionally and personally
				based on my studies, experience, and learnings.
			</p>

			<!-- Temas populares -->
			<div>
				<p
					class="text-xs font-bold tracking-widest uppercase text-text-muted mb-4"
				>
					Popular topics
				</p>
				<div class="flex flex-wrap gap-2">
					{
						popularTags.length > 0 ? (
							popularTags.map((tag) => (
								<span class="px-4 py-1.5 text-sm rounded-full border border-border-subtle text-text-muted hover:border-brand hover:text-brand transition-colors cursor-pointer">
									#{tag}
								</span>
							))
						) : (
							<span class="text-sm text-text-faint italic">
								No tags yet
							</span>
						)
					}
				</div>
			</div>
		</header>

		<section class="space-y-12">
			{
				posts.map((post, index) => (
					<article
						class="group relative"
						style={`animation-delay: ${index * 80}ms`}
					>
						<div class="p-8 md:p-10 rounded-card bg-surface-raised border border-border-subtle hover:bg-surface-hover hover:border-border-hover transition-all duration-slow">
							<div class="flex flex-col gap-6">
								<div class="flex items-center gap-4 text-xs font-bold tracking-widest uppercase text-text-muted">
									<div class="flex gap-2">
										{(post.tags ?? []).map((t) => (
											<span class="text-brand font-black">
												#{t.value}
											</span>
										))}
									</div>
									<span class="w-1 h-1 bg-border-muted rounded-full" />
									<span>
										{new Date(
											post.date || post.createdAt,
										).toLocaleDateString("en-US", {
											day: "2-digit",
											month: "short",
											year: "numeric",
										})}
									</span>
								</div>

								<a
									href={`/en/blog/${post.slug}`}
									class="block transition-opacity"
								>
									<h2 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-brand-hover transition-colors duration-normal">
										{post.title}
									</h2>
								</a>

								<p class="text-text-secondary text-lg leading-relaxed">
									{post.excerpt ||
										post.content?.root?.children?.[0]?.children?.[0]?.text?.substring(
											0,
											160,
										) + "..." ||
										"No description available."}
								</p>

								<a
									href={`/en/blog/${post.slug}`}
									class="inline-flex items-center text-sm font-bold text-text-primary hover:text-white group/link"
								>
									Read more
									<svg
										xmlns="http://www.w3.org/2000/svg"
										class="w-4 h-4 ml-2 group-hover/link:translate-x-1 transition-transform"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
									>
										<path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2.5"
											d="M14 5l7 7m0 0l-7 7m7-7H3"
										/>
									</svg>
								</a>
							</div>
						</div>
					</article>
				))
			}
		</section>
	</main>
</Layout>
